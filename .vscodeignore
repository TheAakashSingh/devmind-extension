# Exclude everything by default, then whitelist what we need
.vscode/**
.vscode-test/**
.gitignore
.git/**
.claude/**
*.vsix

# Exclude TypeScript source files (compiled to dist/)
src/**

# Exclude node_modules and dev files
node_modules/**
**/*.map
.eslintrc.json
tsconfig.json
tsconfig.tsbuildinfo

# NOTE: dist/ is NOT excluded — it contains compiled JS + dist/webview/chat.html
# NOTE: assets/ is NOT excluded — it contains logo.png
# NOTE: README.md is NOT excluded — shown in marketplace
